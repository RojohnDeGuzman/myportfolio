# Groq API key for the portfolio chat bot (server-side only).
# Get a key at https://console.groq.com/
# For Vercel: set this in Project → Settings → Environment Variables.
GROQ_API_KEY=

# Optional: for local dev with "npm run dev", set this to your Vercel deployment URL
# so the chat uses your deployed API (where GROQ_API_KEY is set). Example:
# VITE_CHAT_API_BASE=https://myportfolio-lac-delta.vercel.app
VITE_CHAT_API_BASE=
